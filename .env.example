# Consciousness Gateway — Environment Configuration
#
# Copy this file to .env and fill in your API keys.
# At least one model provider key is required for real responses.
# Without any keys, the gateway runs in fallback mode (placeholder responses).

# ─── Model Provider API Keys ─────────────────────────────────────
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get yours at: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Get yours at: https://console.x.ai/
# Used for Grok model routing and web browse summarization
XAI_API_KEY=

# ─── Gateway Configuration ───────────────────────────────────────
PORT=3000

# ─── Consciousness Layer ─────────────────────────────────────────
# GitHub Personal Access Token (for repository monitoring)
# Get yours at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Comma-separated list of repos to monitor
GITHUB_REPOS=Move37LLC/consciousness-gateway,Move37LLC/Consciousness-Aware-Aligned-AI

# ─── Telegram Bot ─────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, get the token
TELEGRAM_BOT_TOKEN=
# Your personal chat ID (message @userinfobot to get it)
TELEGRAM_CHAT_ID=
# Hour to send daily summary (0-23, default 8)
TELEGRAM_DAILY_HOUR=8

# ─── Web Tools ─────────────────────────────────────────────────
# Brave Search API key (for /search command)
# Get yours at: https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=

# ─── Memory / Transcripts ────────────────────────────────────────
# Directory holding past-conversation transcripts (.txt/.md/.log) that
# the [TRANSCRIPT:] tool searches. Defaults to /mnt/transcripts (Linux).
# On macOS (e.g. the Mac Mini) that path does NOT exist — you MUST set this.
#
# Setup:
#   mkdir -p ~/consciousness-gateway/transcripts
#   echo 'TRANSCRIPTS_DIR=/Users/javimercado/consciousness-gateway/transcripts' >> .env
#   npm run export:transcripts   # dump conversation_history → .txt files
#   # (or restart the gateway — it auto-exports on boot when TRANSCRIPTS_DIR is set)
#
# Trading channel is excluded from export by default (high volume, low recall value).
TRANSCRIPTS_DIR=
# ─── Optional Monitors ───────────────────────────────────────────
# Twitter/X Bearer Token (optional, for social monitoring)
# TWITTER_BEARER_TOKEN=

# Physical sensation channel (Phase 3 scaffold). Set to 1 to enable the
# SYNTHETIC sensor source — exercises the full ingress → arousal-filter →
# fusion pipeline with no hardware. Sensation percepts are structurally
# barred from forming intentions (type-system boundary + intention-engine
# choke point). Leave unset for a plain restart no-op.
# SENSORS_SYNTHETIC=1
# Which synthetic modalities to activate (comma list). Default: synthetic.
# Options: synthetic, em_spectrum, gravitational, field_magnetic, field_imu,
#          field_environment, quantum_rng
# SENSORS_SYNTHETIC_MODALITIES=synthetic
# Deterministic replay seed (integer). Unset → Math.random.
# SENSORS_SEED=42

# Email IMAP (optional, for email monitoring)
# EMAIL_HOST=
# EMAIL_PORT=993
# EMAIL_USER=
# EMAIL_PASSWORD=

# ─── Hermes Bridge (Pattern B integration) ──────────────────────
# MCP-over-HTTP endpoint of a running hermes-agent instance.
# When set, the consciousness loop can discharge intentions into Hermes
# (spawn_subagent, run_skill, run_tool, send_channel, schedule_cron, ...)
# through the dharma + ethos gate. When unset, all hermes.* intentions
# fail authorization gracefully and the loop keeps ticking.
# Start Hermes with: python mcp_serve.py --host 0.0.0.0 --port 7821
# HERMES_MCP_URL=http://localhost:7821/mcp
# HERMES_AUTH_TOKEN=
